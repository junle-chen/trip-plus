# Local environment and secrets
.gitignore
.env
.env.*
!.env.example

# Python bytecode and tool caches
__pycache__/
*.py[cod]
*$py.class
.cache/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/

# Virtual environments
.venv/
venv/
env/
ENV/

# Local agent/editor metadata
.agents/
.codex/
.vscode/
.idea/
.DS_Store
.ipynb_checkpoints/

# Runtime logs and generated outputs
log/
logs/
result/
results/
output/
outputs/
tmp/
temp/
*.log

# Generated reports and heavy local artifacts
*.pdf
*.zip
*.tar
*.tar.gz
*.tgz

# Local release notes not needed in the public upload
OPEN_SOURCE_RELEASE.md

# Full local benchmark database. Keep the bundled smoke-test samples and one
# city-level Beijing example for reviewer inspection.
database/*
!database/README.md
!database/en/
database/en/*
!database/en/beijing/
!database/en/beijing/**
!database/sample/
database/sample/*
!database/sample/en/
database/sample/en/*
!database/sample/en/id_0005/
!database/sample/en/id_0005/**
!database/sample/en/id_0006/
!database/sample/en/id_0006/**

# Human-readable query exports
query/query_en/multiturn/query_570_turns.txt

# Optional multi-turn split/group views; keep only query.json and query_raw.json
query/query_en/multiturn/_index.json
query/query_en/multiturn/items/
query/query_en/multiturn/environment_driven_replanning/
query/query_en/multiturn/long_horizon_alignment/
query/query_en/multiturn/request_resolution/
query/query_en/multiturn/user_state_evolution/

# Optional single-turn benchmark data (not needed for multi-turn-only release)
query/query_en/single/
AGENTS.md
